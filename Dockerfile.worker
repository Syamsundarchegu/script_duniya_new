# బేస్ ఇమేజ్
FROM python:3.11-slim

# వర్కింగ్ డైరెక్టరీ సెటప్
WORKDIR /app

# పైథాన్ లాగ్స్ కన్సోల్ లో వెంటనే ప్రింట్ అవ్వడానికి (ఎర్రర్స్ చెక్ చేయడానికి ఇది చాలా ముఖ్యం)
ENV PYTHONUNBUFFERED=1

# రిక్వైర్మెంట్స్ కాపీ చేసి ఇన్స్టాల్ చేయండి
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# కోడ్ కాపీ చేయండి
COPY . .

# వర్కర్ స్క్రిప్ట్ ని స్టార్ట్ చేసే కమాండ్
CMD ["python", "worker.py"]