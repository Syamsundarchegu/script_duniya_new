# బేస్ ఇమేజ్ (LangGraph/LangChain కి పైథాన్ 3.11 బెస్ట్)
FROM python:3.11-slim

# వర్కింగ్ డైరెక్టరీ సెటప్
WORKDIR /app

# పైథాన్ లాగ్స్ కన్సోల్ లో వెంటనే ప్రింట్ అవ్వడానికి
ENV PYTHONUNBUFFERED=1

# ముందుగా రిక్వైర్మెంట్స్ కాపీ చేసి ఇన్స్టాల్ చేయండి
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# మిగతా కోడ్ అంతా కాపీ చేయండి
COPY . .

# FastAPI రన్ అవ్వాల్సిన పోర్ట్
EXPOSE 8000

# అప్లికేషన్ స్టార్ట్ చేసే కమాండ్
CMD ["uvicorn", "backend:app", "--host", "0.0.0.0", "--port", "8000"]